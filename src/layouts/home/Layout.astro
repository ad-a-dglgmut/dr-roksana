---
import Langselect from "../../components/Langselect.svelte"
import Navbar from "../../components/Navbar"

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html class="scroll-smooth" lang="en">
	<head>
		<meta charset="UTF-8" />
    <meta name="description" content="Ординација по општа стоматологија „Д-р Роксана Петковска-Божинова“ | General dental office „Dr. Roksana Petkovska Bozhinova“" />
		<meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/x-ico" href="/public/logo.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>

	<body class="relative z-20">
    <Navbar client:only="react"/>
		<slot />
    <Langselect client:only="svelte"/>
	</body>
</html>
