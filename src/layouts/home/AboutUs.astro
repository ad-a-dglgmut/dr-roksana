---
 const { id } = Astro.props
---
<div id={id} class="w-full py-[96px] lg:flex min-h-screen ">
  <div class="w-full lg:mr-10 xl:mr-0">
    <slot/>
  </div>

  <div class="w-full flex mt-10 lg:mt-0 justify-end px-5">
    <img class="lg:h-[calc(100vh_-_96px)] object-contain rounded-xl lg:mr-10 " src="https://res.cloudinary.com/dxvfgwkpx/image/upload/v1779463951/3_lyixor.jpg"/>
  </div> 

</div>
