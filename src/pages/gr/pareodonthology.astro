---
// import "@/styles/app.css"
import Layout from "../../layouts/home/Layout.astro"
import Intro from "../../layouts/interventions_layouts/Intro.astro"
import Content from "../../layouts/interventions_layouts/Content.astro"
---
<Layout title="Περιοδοντολογία">
  <Intro imgSrc="https://res.cloudinary.com/dxvfgwkpx/image/upload/v1727817735/paradonttt_ouw6fn.png">
    <div class="lg:w-full lg:h-full items-center lg:flex ">
      <div class="lg:ml-10 lg:mt-10">
        <h2 class="lg:text-9xl text-5xl text-red-500 font-bold">Περιοδοντολογία</h2>
      </div>
    </div>
  </Intro>
  <div class="w-full bg-red-500 py-[96px] min-h-screen ">
    <Content imgSrc="https://res.cloudinary.com/dxvfgwkpx/image/upload/v1727817734/paradont_lgzzqf.jpg">
      <div>
        <p class="text-2xl">Αυτή είναι μια πολύ σημαντική πτυχή των οδοντιατρικών θεραπειών, χωρίς την οποία δεν μπορεί να φανταστεί κανείς μια ποιοτική και επιτυχημένη συντηρητική-προσθετική θεραπεία σήμερα, και σχετίζεται με την υγεία των ιστών των ούλων (γίνειβα), του οστού και άλλων υποστηρικτικών δομών. Η θεραπεία περιλαμβάνει τον καθαρισμό του τάρταρου, τη θεραπεία των λεγόμενων γυναικείων θυλάκων, την παροχή οδηγιών στοματικής υγιεινής και την τοπική εφαρμογή φαρμάκων.</p>
      </div>
    </Content>

  </div>
</Layout>
